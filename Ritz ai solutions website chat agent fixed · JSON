        "jsCode": "const item = $input.first();\nconst agentResponse = (item.json.output || '').toLowerCase();\nconst userMessage = ($('Input Validator + Rate Limiter').first().json.message || '').toLowerCase();\nconst sessionId = $('Input Validator + Rate Limiter').first().json.sessionId || '';\nconst timestamp = new Date().toISOString();\n\nconst INTENT_KEYWORDS = [\n  'interested','proposal','quote','pricing','price','how much','cost',\n  'book a call','discovery call','schedule a call','get started',\n  'contact kevin','reach out','get in touch','next steps',\n  'work with you','partner with','hire you','lets work together',\n  \"let's work together\",'move forward','onboard','sign up'\n];\nconst COMPETITOR_SIGNALS = [\n  'comparing','other agencies','also talking to','alternatives','other options'\n];\n\nlet lead_score = 0;\nconst combined = userMessage + ' ' + agentResponse;\nconst intentHits = INTENT_KEYWORDS.filter(k => combined.includes(k));\nif (intentHits.length >= 3) lead_score = 3;\nelse if (intentHits.length === 2) lead_score = 2;\nelse if (intentHits.length === 1) lead_score = 1;\nif (COMPETITOR_SIGNALS.some(k => combined.includes(k))) lead_score = Math.min(lead_score + 1, 3);\nif (agentResponse.includes('kevin@ritz-ai.solutions')) lead_score = Math.min(lead_score + 1, 3);\nconst intent_flag = lead_score >= 1;\n\nconst ESCALATION_KEYWORDS = [\n  'speak to a human','talk to a human','speak to kevin','talk to kevin',\n  'real person','human support','not helpful','this is useless',\n  'i give up','forget it','frustrated','terrible','awful','waste of time','urgent','emergency','asap'\n];\nconst escalation_hits = ESCALATION_KEYWORDS.filter(k => userMessage.includes(k));\nconst escalation_flag = escalation_hits.length > 0 || agentResponse.includes('kevin@ritz-ai.solutions');\nconst escalation_reason = escalation_hits.length > 0\n  ? 'Triggered by: ' + escalation_hits.join(', ')\n  : agentResponse.includes('kevin@ritz-ai.solutions') ? 'Agent directed user to Kevin' : '';\n\nreturn [{ json: {\n  output: item.json.output || '',\n  sessionId,\n  userMessage: $('Input Validator + Rate Limiter').first().json.message || '',\n  agentResponse: item.json.output || '',\n  timestamp,\n  lead_score,\n  intent_flag,\n  intent_triggers: intentHits.join(', '),\n  escalation_flag,\n  escalation_reason\n}}];"
