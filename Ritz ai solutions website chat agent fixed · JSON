      "parameters": {
        "jsCode": "// ============================================================\n// INPUT VALIDATOR + RATE LIMITER\n// Runs immediately after Webhook, before AI Agent\n// Protects against empty input, token bombing, injection,\n// and per-session message rate abuse\n// ============================================================\n\nconst item = $input.first();\nconst body = item.json.body || item.json;\n\n// ---- Extract fields ----\nlet message   = (body.message || '').toString();\nlet sessionId = (body.sessionId || '').toString().trim();\nconst consent = body.consent; // expected: true\n\n// ---- 1. GDPR Consent Gate ----\n// Uncomment once chat widget sends consent flag\nif (consent !== true) {\n  return [{ json: { valid: false, error: 'consent_required', message: 'Chat requires consent to data processing.' } }];\n}\n\n// ---- 2. Empty message check ----\nif (!message || message.trim().length === 0) {\n  return [{ json: { valid: false, error: 'empty_message', message: 'Please type a message before sending.' } }];\n}\n\n// ---- 3. Token bomb protection: trim to 1000 chars ----\nmessage = message.trim().substring(0, 1000);\n\n// ---- 4. Strip HTML tags and basic injection patterns ----\nmessage = message\n  .replace(/<[^>]*>/g, '')           // strip HTML tags\n  .replace(/javascript:/gi, '')      // strip JS protocol\n  .replace(/on\\w+\\s*=/gi, '')        // strip event handlers\n  .replace(/\\bignore\\s+previous\\s+instructions?\\b/gi, '[filtered]')\n  .replace(/\\bact\\s+as\\s+if\\b/gi, '[filtered]')\n  .replace(/\\bsystem\\s*:\\s*new\\b/gi, '[filtered]');\n\n// ---- 5. Generate fallback sessionId if missing ----\nif (!sessionId || sessionId.length < 4) {\n  sessionId = 'auto_' + Date.now().toString(36) + Math.random().toString(36).substr(2, 5);\n}\n\n// ---- 6. Rate Limiter (20 msgs per 10-min window per session) ----\nconst MAX_MESSAGES = 20;\nconst WINDOW_MS    = 10 * 60 * 1000; // 10 minutes\nconst now          = Date.now();\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.rateLimits) staticData.rateLimits = {};\n\nconst entry = staticData.rateLimits[sessionId];\n\nif (entry && (now - entry.windowStart) < WINDOW_MS) {\n  if (entry.count >= MAX_MESSAGES) {\n    return [{ json: {\n      valid: false,\n      error: 'rate_limit',\n      message: 'You have sent too many messages. Please wait a few minutes and try again.'\n    }}];\n  }\n  entry.count += 1;\n} else {\n  // New window\n  staticData.rateLimits[sessionId] = { count: 1, windowStart: now };\n}\n\n// ---- Cleanup old sessions (avoid memory bloat) ----\nfor (const sid of Object.keys(staticData.rateLimits)) {\n  if ((now - staticData.rateLimits[sid].windowStart) > WINDOW_MS * 2) {\n    delete staticData.rateLimits[sid];\n  }\n}\n\n// ---- 7. Pass through validated data ----\nreturn [{ json: {\n  valid:     true,\n  message:   message,\n  sessionId: sessionId,\n  consent:   consent || false,\n  timestamp: new Date().toISOString()\n}}];"
